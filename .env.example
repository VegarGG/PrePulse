# --- Mode ---
PREPULSE_LIVE=0
PREPULSE_LOG_LEVEL=INFO

# --- LLM providers ---
# Selectable provider chain. The chosen index is used first; the others
# auto-fall-back via langchain's with_fallbacks if the chosen one errors.
# Providers without a key are skipped entirely; the system never picks
# an unconfigured provider.
#   0 = anthropic   (default; claude-sonnet-4-6)
#   1 = openai      (gpt-4o)
#   2 = deepseek    (deepseek-v4-flash, OpenAI-compatible at api.deepseek.com)
# You may also set this by name: PREPULSE_API_PROVIDER=deepseek
PREPULSE_API_PROVIDER=0

ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-6           # optional override

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o                          # optional override

DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash             # optional; deepseek-v4-pro etc. also work
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# --- Chatbot semantic-similarity gate ---
# Fine-grained token from https://huggingface.co/settings/tokens with the
# "Make calls to Inference Providers" permission enabled.
HUGGINGFACE_API_TOKEN=
# Optional override; default is sentence-transformers/all-MiniLM-L6-v2
# PREPULSE_HF_EMBEDDING_MODEL=
# Default thresholds calibrated for all-MiniLM-L6-v2: 0.35 / 0.65
# (raised from 0.25 after the validation campaign showed 7/30 off-topic
# questions slipping past 0.25; see validation/reports/FINAL_combined_report.md)
# PREPULSE_KB_LOW_THRESHOLD=0.35
# PREPULSE_KB_HIGH_THRESHOLD=0.65

# --- Threat-intel APIs (only read when PREPULSE_LIVE=1) ---
OTX_API_KEY=
HIBP_API_KEY=
ABUSEIPDB_API_KEY=
NVD_API_KEY=

# --- Frontend ---
NEXT_PUBLIC_API_BASE=http://localhost:8001
